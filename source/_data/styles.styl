// ============================================
// 杀戮尖塔 (Slay the Spire) 主题样式
// ============================================

// 杀戮尖塔配色方案
$sts-dark-bg = #1a1a2e
$sts-purple = #4a3b69
$sts-purple-light = #6b5b8a
$sts-gold = #c9a227
$sts-green = #4ade80
$sts-red = #dc2626
$sts-blue = #3b82f6
$sts-card-border = #8b7355

// 全局背景
body {
  background: linear-gradient(135deg, #0d0d1a 0%, #1a1a2e 50%, #16213e 100%);
  background-attachment: fixed;
  position: relative;
}

// 添加神秘符文背景图案
body::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
    radial-gradient(circle at 20% 50%, rgba(74, 59, 105, 0.15) 0%, transparent 50%),
    radial-gradient(circle at 80% 80%, rgba(201, 162, 39, 0.1) 0%, transparent 40%),
    radial-gradient(circle at 40% 20%, rgba(74, 222, 128, 0.08) 0%, transparent 35%);
  pointer-events: none;
  z-index: -1;
}

// 头部样式 - 杀戮尖塔风格
.header {
  background: linear-gradient(180deg, rgba(13, 13, 26, 0.95) 0%, rgba(26, 26, 46, 0.9) 100%);
  border-bottom: 3px solid $sts-gold;
  box-shadow: 0 4px 20px rgba(201, 162, 39, 0.3);
}

// 网站标题样式
.brand {
  background: linear-gradient(135deg, $sts-gold 0%, #f4d03f 50%, $sts-gold 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 30px rgba(201, 162, 39, 0.5);
  font-weight: bold;
  letter-spacing: 2px;
}

// 导航菜单
.menu-item a {
  color: #d1d5db !important;
  transition: all 0.3s ease;
  position: relative;
}

.menu-item a:hover {
  color: $sts-gold !important;
  text-shadow: 0 0 10px rgba(201, 162, 39, 0.8);
}

// 文章卡片样式 - 仿杀戮尖塔卡牌
.post-block {
  background: linear-gradient(145deg, #1e1e32 0%, #2a2a45 100%);
  border: 2px solid $sts-card-border;
  border-radius: 12px;
  box-shadow: 
    0 8px 32px rgba(0, 0, 0, 0.4),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
  margin-bottom: 30px;
}

// 卡牌光泽效果
.post-block::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(201, 162, 39, 0.03) 50%,
    transparent 70%
  );
  transform: rotate(45deg);
  pointer-events: none;
}

// 卡牌边框发光效果
.post-block:hover {
  border-color: $sts-gold;
  box-shadow: 
    0 8px 32px rgba(0, 0, 0, 0.4),
    0 0 20px rgba(201, 162, 39, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

// 文章标题
.post-title a {
  color: #f3f4f6 !important;
  transition: all 0.3s ease;
}

.post-title a:hover {
  color: $sts-gold !important;
  text-shadow: 0 0 15px rgba(201, 162, 39, 0.5);
}

// 文章元信息
.post-meta {
  color: #9ca3af !important;
}

.post-meta a {
  color: $sts-purple-light !important;
}

.post-meta a:hover {
  color: $sts-green !important;
}

// 侧边栏样式
.sidebar {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  border: 2px solid $sts-purple;
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

// 侧边栏标题
.sidebar-title {
  color: $sts-gold !important;
  border-bottom: 2px solid $sts-purple;
  padding-bottom: 10px;
}

// 标签云样式
tag-cloud a {
  background: linear-gradient(135deg, $sts-purple 0%, $sts-purple-light 100%);
  border: 1px solid $sts-gold;
  color: #fff !important;
  border-radius: 20px;
  padding: 4px 12px;
  transition: all 0.3s ease;
}

tag-cloud a:hover {
  background: linear-gradient(135deg, $sts-gold 0%, #f4d03f 100%);
  color: #1a1a2e !important;
  box-shadow: 0 0 15px rgba(201, 162, 39, 0.5);
  transform: translateY(-2px);
}

// 按钮样式
.btn {
  background: linear-gradient(135deg, $sts-purple 0%, $sts-purple-light 100%);
  border: 2px solid $sts-gold;
  color: #fff;
  border-radius: 8px;
  transition: all 0.3s ease;
}

.btn:hover {
  background: linear-gradient(135deg, $sts-gold 0%, #f4d03f 100%);
  color: #1a1a2e;
  box-shadow: 0 0 20px rgba(201, 162, 39, 0.4);
}

// 分页样式
.pagination {
  background: linear-gradient(135deg, #1e1e32 0%, #2a2a45 100%);
  border: 2px solid $sts-purple;
  border-radius: 8px;
}

.pagination a, .pagination span {
  color: #d1d5db !important;
  border-color: $sts-purple !important;
}

.pagination a:hover {
  background: $sts-purple !important;
  color: $sts-gold !important;
}

.pagination .current {
  background: $sts-gold !important;
  color: #1a1a2e !important;
  border-color: $sts-gold !important;
}

// 页脚样式
.footer {
  background: linear-gradient(180deg, #0d0d1a 0%, #1a1a2e 100%);
  border-top: 3px solid $sts-purple;
  color: #9ca3af;
}

.footer a {
  color: $sts-purple-light !important;
}

.footer a:hover {
  color: $sts-gold !important;
}

// 代码块样式
pre, code {
  background: #0d0d1a !important;
  border: 1px solid $sts-purple;
  border-radius: 6px;
}

code {
  color: $sts-green !important;
}

pre code {
  color: #d1d5db !important;
}

// 引用块样式
blockquote {
  background: linear-gradient(90deg, rgba(74, 59, 105, 0.3) 0%, transparent 100%);
  border-left: 4px solid $sts-gold;
  color: #d1d5db;
}

// 链接样式
a {
  color: $sts-purple-light;
  transition: all 0.3s ease;
}

a:hover {
  color: $sts-gold;
}

// 滚动条样式
::-webkit-scrollbar {
  width: 10px;
}

::-webkit-scrollbar-track {
  background: #0d0d1a;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, $sts-purple 0%, $sts-purple-light 100%);
  border-radius: 5px;
  border: 2px solid #0d0d1a;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, $sts-gold 0%, #f4d03f 100%);
}

// 选中文字样式
::selection {
  background: rgba(201, 162, 39, 0.3);
  color: #fff;
}

// 动画效果
@keyframes glow {
  0%, 100% {
    box-shadow: 0 0 5px rgba(201, 162, 39, 0.5);
  }
  50% {
    box-shadow: 0 0 20px rgba(201, 162, 39, 0.8), 0 0 40px rgba(201, 162, 39, 0.4);
  }
}

@keyframes float {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-10px);
  }
}

// 漂浮动画类
.float-animation {
  animation: float 3s ease-in-out infinite;
}

// 发光动画类
.glow-animation {
  animation: glow 2s ease-in-out infinite;
}

// 阅读更多按钮
.post-button .btn {
  background: linear-gradient(135deg, rgba(201, 162, 39, 0.2) 0%, rgba(201, 162, 39, 0.1) 100%);
  border-color: $sts-gold;
  color: $sts-gold;
}

.post-button .btn:hover {
  background: linear-gradient(135deg, $sts-gold 0%, #f4d03f 100%);
  color: #1a1a2e;
}

// 分割线样式
hr {
  border: none;
  height: 2px;
  background: linear-gradient(90deg, transparent 0%, $sts-purple 50%, transparent 100%);
  margin: 30px 0;
}

// 表格样式
table {
  background: #1e1e32;
  border: 2px solid $sts-purple;
  border-radius: 8px;
}

th {
  background: $sts-purple;
  color: $sts-gold;
}

td {
  border-color: $sts-purple;
  color: #d1d5db;
}

tr:hover {
  background: rgba(74, 59, 105, 0.3);
}
